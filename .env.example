# ══════════════════════════════════════════════
#  FitJejak — Environment Variables
#  Salin fail ini: cp .env.example .env
#  Kemudian isi nilai yang betul
# ══════════════════════════════════════════════

# Dapatkan token dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Pilih AI provider: "openai" atau "gemini"
AI_PROVIDER=openai

# Jika guna OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Jika guna Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Path database (biarkan default)
DATABASE_PATH=data/fitjejak.db
